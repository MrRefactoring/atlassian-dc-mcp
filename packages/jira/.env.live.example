# Copy this file to .env.live (gitignored) and fill in real values to run
# packages/jira/src/__tests__/live/jira-service.live.test.ts against a real
# Jira Data Center instance:
#
#   pnpm --filter jira-datacenter-mcp test -- jira-service.live
#
# Either an API token or a username/password pair is enough — you don't need
# both. Never commit the filled-in .env.live.

JIRA_HOST=jira.example.com
# JIRA_API_BASE_PATH=/rest

JIRA_API_TOKEN=

# JIRA_USERNAME=
# JIRA_PASSWORD=
