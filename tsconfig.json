{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "datacenter-mcp-core": ["./packages/core/src"],
      "datacenter-mcp-core/setup-cli": ["./packages/core/src/setup-cli"]
    }
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/jira" },
    { "path": "packages/confluence" },
    { "path": "packages/bitbucket" }
  ]
}
