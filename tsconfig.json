{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "jest"],
    "paths": {
      "@mrrefactoring/atlassian-dc-mcp-core": ["./packages/core/src"]
    }
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/jira" },
    { "path": "packages/confluence" },
    { "path": "packages/bitbucket" }
  ]
}
