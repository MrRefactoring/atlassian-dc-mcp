{
  "name": "atlassian-dc-mcp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrRefactoring/atlassian-dc-mcp.git"
  },
  "homepage": "https://github.com/MrRefactoring/atlassian-dc-mcp#readme",
  "bugs": {
    "url": "https://github.com/MrRefactoring/atlassian-dc-mcp/issues"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter datacenter-mcp-core build && pnpm -r build",
    "test": "pnpm -r test",
    "dev:jira": "pnpm --filter jira-datacenter-mcp dev",
    "dev:confluence": "pnpm --filter confluence-datacenter-mcp dev",
    "dev:bitbucket": "pnpm --filter bitbucket-datacenter-mcp dev",
    "debug": "node mcp-live-debug.js",
    "debug:verbose": "node mcp-live-debug.js --verbose",
    "debug:ts": "tsx watch",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-versions.js && pnpm install --lockfile-only",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.0",
    "jest": "^30.4.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
